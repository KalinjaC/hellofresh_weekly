<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Menu HellFresh · {{ week_label }}</title>
  <link rel="manifest" href="manifest.json"/>
  <meta name="theme-color" content="#98c240"/>
  <meta name="apple-mobile-web-app-capable" content="yes"/>
  <meta name="apple-mobile-web-app-title" content="HellFresh"/>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config={theme:{extend:{colors:{hf:'#98c240','hf-dark':'#7aa832'}}}}</script>
  <style>
    .card-selected { outline: 2.5px solid #98c240; box-shadow: 0 0 0 4px #98c24025; }
    .accordion-body { display: none; }
    .accordion-body.open { display: block; }
    .step-num { min-width:1.6rem;min-height:1.6rem;background:#98c240;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.75rem;flex-shrink:0; }
    .tag-veggie  { background:#dcfce7;color:#16a34a; }
    .tag-epice   { background:#fee2e2;color:#dc2626; }
    .tag-rapide  { background:#fef9c3;color:#ca8a04; }
    .tag-default { background:#f3f4f6;color:#6b7280; }
    input[type=range] { accent-color:#98c240; }
  </style>
</head>
<body class="bg-gray-50 text-gray-800 font-sans min-h-screen">

<!-- ═══ HEADER ═══ -->
<header class="bg-white shadow-sm sticky top-0 z-50">
  <div class="max-w-2xl mx-auto px-4 py-3 flex items-center justify-between">
    <div>
      <h1 class="text-xl font-bold text-hf">🍽️ HellFresh</h1>
      <p class="text-xs text-gray-400">{{ week_label }} · {{ generated_at }}</p>
    </div>
    <div class="text-right">
      <p class="text-sm font-semibold text-hf" id="sel-count">0 sélectionnée(s)</p>
      <button onclick="showTab('shop')"
        class="text-xs bg-hf text-white px-3 py-1 rounded-full mt-1 hidden" id="shop-btn">
        Voir liste de courses →
      </button>
    </div>
  </div>
  <!-- Tabs -->
  <div class="max-w-2xl mx-auto px-4 flex gap-1 pb-2">
    <button id="tab-recipes" onclick="showTab('recipes')"
      class="px-4 py-1.5 rounded-full text-sm font-medium bg-hf text-white">
      📋 Recettes ({{ items|length }})
    </button>
    <button id="tab-shop" onclick="showTab('shop')"
      class="px-4 py-1.5 rounded-full text-sm font-medium bg-gray-100 text-gray-500">
      🛒 Liste de courses
    </button>
  </div>
</header>

<main class="max-w-2xl mx-auto px-3 pb-20">

<!-- ═══ RECETTES ═══ -->
<div id="pane-recipes">
  <p class="text-xs text-gray-400 my-3 px-1">
    Coche les recettes pour générer la liste de courses automatiquement.
  </p>

  {% if not items %}
  <div class="bg-white rounded-2xl p-8 text-center text-gray-400 mt-4">
    <p class="text-4xl mb-3">😕</p>
    <p>Aucune recette trouvée cette semaine.</p>
  </div>
  {% else %}

  <div class="grid grid-cols-2 gap-3 sm:gap-4">
    {% for item in items %}
    {% set idx = loop.index0 %}
    <div class="recipe-card bg-white rounded-2xl overflow-hidden shadow-sm border border-transparent transition-all"
         id="card-{{ idx }}" data-idx="{{ idx }}">

      <!-- Photo + checkbox overlay -->
      <div class="relative">
        {% if item.image %}
        <img src="{{ item.image }}" alt="{{ item.name }}"
          class="w-full aspect-square object-cover"
          loading="lazy" onerror="this.parentElement.classList.add('bg-gray-100'); this.style.display='none'"/>
        {% else %}
        <div class="w-full aspect-square bg-gray-100 flex items-center justify-center text-4xl">🍳</div>
        {% endif %}

        <!-- Checkbox badge -->
        <label class="absolute top-2 right-2 cursor-pointer"
               for="chk-{{ idx }}" title="Sélectionner">
          <input type="checkbox" id="chk-{{ idx }}" class="sr-only recipe-check"
                 onchange="onCheck({{ idx }}, this.checked)"/>
          <span class="flex items-center justify-center w-7 h-7 rounded-full border-2 border-white shadow-md transition-all bg-white/80 check-icon" id="icon-{{ idx }}">
            <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
            </svg>
          </span>
        </label>

        <!-- Veggie badge overlay -->
        {% if item.tags and ('végétar' in (item.tags|join(' '))|lower or 'veggie' in (item.tags|join(' '))|lower) %}
        <span class="absolute top-2 left-2 bg-green-500 text-white text-xs font-bold px-2 py-0.5 rounded-full">🥦 Végé</span>
        {% endif %}
      </div>

      <!-- Card body -->
      <div class="p-3">
        <h3 class="font-semibold text-sm leading-tight line-clamp-2 mb-1">{{ item.name }}</h3>

        {% if item.recipe and item.recipe.name and item.recipe.name != item.name %}
        <p class="text-xs text-gray-400 line-clamp-1 mb-1">{{ item.recipe.name }}</p>
        {% endif %}

        <!-- Time + tags row -->
        <div class="flex flex-wrap items-center gap-1 mt-1.5">
          {% if item.duration %}
          <span class="text-xs text-gray-500 font-medium">🕐 {{ item.duration }}</span>
          {% elif item.recipe and item.recipe.times %}
          <span class="text-xs text-gray-500 font-medium">🕐 {{ item.recipe.times[0] }}</span>
          {% endif %}

          {% for tag in item.tags[:2] %}
          {% set tl = tag|lower %}
          {% if 'végétar' in tl or 'veggie' in tl %}
          <span class="text-xs tag-veggie px-1.5 py-0.5 rounded-full">{{ tag }}</span>
          {% elif 'épicé' in tl or 'piment' in tl %}
          <span class="text-xs tag-epice px-1.5 py-0.5 rounded-full">🌶 {{ tag }}</span>
          {% elif 'rapide' in tl %}
          <span class="text-xs tag-rapide px-1.5 py-0.5 rounded-full">⚡ {{ tag }}</span>
          {% else %}
          <span class="text-xs tag-default px-1.5 py-0.5 rounded-full">{{ tag }}</span>
          {% endif %}
          {% endfor %}
        </div>

        <!-- Expand ingredients button -->
        {% if item.recipe and item.recipe.ingredients %}
        <button onclick="toggleDetails({{ idx }})"
          class="mt-2 w-full text-left text-xs text-hf font-medium flex items-center justify-between border-t border-gray-100 pt-2">
          <span>Ingrédients & étapes</span>
          <svg id="arr-{{ idx }}" class="w-3.5 h-3.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        {% elif item.url %}
        <a href="{{ item.url }}" target="_blank"
           class="mt-2 block text-xs text-hf border-t border-gray-100 pt-2">
          Voir la recette →
        </a>
        {% else %}
        <a href="https://www.hellofresh.fr/recipes?q={{ item.name | urlencode }}"
           target="_blank" class="mt-2 block text-xs text-hf border-t border-gray-100 pt-2">
          Rechercher →
        </a>
        {% endif %}
      </div>

      <!-- Accordion details (spans full width of card) -->
      {% if item.recipe and (item.recipe.ingredients or item.recipe.steps) %}
      <div class="accordion-body border-t border-gray-100 bg-gray-50" id="details-{{ idx }}">
        <!-- sub-tabs -->
        <div class="flex border-b border-gray-100 px-3">
          <button class="detail-tab py-2 mr-4 text-xs font-semibold text-hf border-b-2 border-hf"
                  onclick="switchDetailTab({{ idx }},'ing',this)">Ingrédients</button>
          {% if item.recipe.steps %}
          <button class="detail-tab py-2 text-xs text-gray-400"
                  onclick="switchDetailTab({{ idx }},'steps',this)">Étapes</button>
          {% endif %}
        </div>

        <!-- Ingredients panel -->
        <div id="det-ing-{{ idx }}" class="px-3 py-2">
          <ul class="space-y-1.5">
            {% for ing in item.recipe.ingredients %}
            <li class="flex items-start gap-1.5 text-xs">
              <span class="text-hf mt-0.5">•</span>
              <span class="ingredient-item"
                data-amount="{{ ing.amount or '' }}"
                data-unit="{{ ing.unit or '' }}"
                data-name="{{ ing.name }}"
                data-base="{{ item.recipe.base_servings }}">{{ ing.raw }}</span>
            </li>
            {% endfor %}
          </ul>
        </div>

        <!-- Steps panel -->
        {% if item.recipe.steps %}
        <div id="det-steps-{{ idx }}" class="px-3 py-2 hidden">
          <ol class="space-y-2.5">
            {% for step in item.recipe.steps %}
            <li class="flex gap-2 text-xs">
              <span class="step-num">{{ loop.index }}</span>
              <span class="leading-relaxed text-gray-700">{{ step }}</span>
            </li>
            {% endfor %}
          </ol>
        </div>
        {% endif %}

      </div>
      {% endif %}

    </div>
    {% endfor %}
  </div>
  {% endif %}
</div>

<!-- ═══ LISTE DE COURSES ═══ -->
<div id="pane-shop" class="hidden">

  <!-- Adults slider -->
  <div class="bg-white rounded-2xl shadow-sm p-4 mt-4 mb-4">
    <div class="flex items-center justify-between mb-2">
      <span class="text-sm font-medium text-gray-700">Nombre de personnes</span>
      <span class="text-xl font-bold text-hf" id="adults-val">{{ adults }}</span>
    </div>
    <input type="range" min="2" max="8" value="{{ adults }}" step="1" id="adults-slider"
           class="w-full" oninput="onAdults(this)"/>
    <div class="flex justify-between text-xs text-gray-300 mt-1 px-0.5">
      <span>2</span><span>3</span><span>4</span><span>5</span><span>6</span><span>7</span><span>8</span>
    </div>
  </div>

  <!-- Empty state -->
  <div id="shop-empty" class="bg-white rounded-2xl p-8 text-center text-gray-400">
    <p class="text-4xl mb-3">☝️</p>
    <p class="text-sm">Sélectionne des recettes dans l'onglet Recettes<br>pour générer ta liste de courses.</p>
    <button onclick="showTab('recipes')" class="mt-4 text-sm text-hf underline">
      Aller aux recettes →
    </button>
  </div>

  <!-- Shopping list -->
  <div id="shop-list" class="hidden">
    <div class="flex items-center justify-between mb-3 px-1">
      <p class="text-sm text-gray-500"><span id="shop-recipe-count">0</span> recette(s) sélectionnée(s)</p>
      <button onclick="clearShop()" class="text-xs text-gray-400 underline">Tout décocher</button>
    </div>
    <div id="shop-items" class="bg-white rounded-2xl shadow-sm overflow-hidden divide-y divide-gray-50"></div>
  </div>
</div>

</main>

<!-- ═══ DATA ═══ -->
<script>
  const ITEMS = {{ items_json }};
  let adults = parseInt(localStorage.getItem('hf_adults') || '{{ adults_json }}');
  let selected = new Set(JSON.parse(localStorage.getItem('hf_sel') || '[]'));
  const shopChecked = JSON.parse(localStorage.getItem('hf_shop_checked') || '{}');
</script>
<script>
// ── Tabs ──────────────────────────────────────────────────────────
function showTab(name) {
  ['recipes','shop'].forEach(t => {
    document.getElementById('pane-' + (t==='shop'?'shop':'recipes')).classList.toggle('hidden', t!==name);
    const btn = document.getElementById('tab-' + t);
    btn.className = t === name
      ? 'px-4 py-1.5 rounded-full text-sm font-medium bg-hf text-white'
      : 'px-4 py-1.5 rounded-full text-sm font-medium bg-gray-100 text-gray-500';
  });
  if (name === 'shop') renderShop();
}

// ── Recipe selection ──────────────────────────────────────────────
function onCheck(idx, checked) {
  const card = document.getElementById('card-' + idx);
  const icon = document.getElementById('icon-' + idx);
  if (checked) {
    selected.add(idx);
    card.classList.add('card-selected');
    icon.className = 'flex items-center justify-center w-7 h-7 rounded-full border-2 border-hf shadow-md bg-hf check-icon';
    icon.querySelector('svg').classList.replace('text-gray-300','text-white');
  } else {
    selected.delete(idx);
    card.classList.remove('card-selected');
    icon.className = 'flex items-center justify-center w-7 h-7 rounded-full border-2 border-white shadow-md bg-white/80 check-icon';
    icon.querySelector('svg').classList.replace('text-white','text-gray-300');
  }
  const n = selected.size;
  document.getElementById('sel-count').textContent = n + ' sélectionnée(s)';
  document.getElementById('shop-btn').classList.toggle('hidden', n === 0);
  localStorage.setItem('hf_sel', JSON.stringify([...selected]));
}

// ── Accordion details ─────────────────────────────────────────────
function toggleDetails(idx) {
  const body = document.getElementById('details-' + idx);
  const arr  = document.getElementById('arr-' + idx);
  const open = body.classList.contains('open');
  body.classList.toggle('open', !open);
  if (arr) arr.style.transform = open ? '' : 'rotate(180deg)';
}

function switchDetailTab(idx, panel, btn) {
  ['ing','steps'].forEach(p => {
    const el = document.getElementById('det-' + p + '-' + idx);
    if (el) el.classList.toggle('hidden', p !== panel);
  });
  btn.closest('.flex').querySelectorAll('.detail-tab').forEach(b => {
    const active = b === btn;
    b.className = active
      ? 'detail-tab py-2 mr-4 text-xs font-semibold text-hf border-b-2 border-hf'
      : 'detail-tab py-2 mr-4 text-xs text-gray-400';
  });
}

// ── Shopping list ─────────────────────────────────────────────────
function getAggregated() {
  const agg = {};
  [...selected].forEach(idx => {
    const item = ITEMS[idx];
    if (!item || !item.recipe || !item.recipe.ingredients) return;
    const base = item.recipe.base_servings || 2;
    const scale = adults / base;
    item.recipe.ingredients.forEach(ing => {
      if (!ing.name) return;
      const key = ing.name.toLowerCase().trim();
      if (!agg[key]) agg[key] = { name: ing.name, unit: ing.unit||'', total: 0, hasAmt: false };
      if (ing.amount && !isNaN(ing.amount)) {
        agg[key].total += ing.amount * scale;
        agg[key].hasAmt = true;
      }
    });
  });
  return agg;
}

function renderShop() {
  const empty = document.getElementById('shop-empty');
  const list  = document.getElementById('shop-list');
  document.getElementById('shop-recipe-count').textContent = selected.size;

  if (selected.size === 0) {
    empty.classList.remove('hidden');
    list.classList.add('hidden');
    return;
  }
  empty.classList.add('hidden');
  list.classList.remove('hidden');

  const agg = getAggregated();
  const items = Object.values(agg).sort((a,b) => a.name.localeCompare(b.name, 'fr'));

  const saved = JSON.parse(localStorage.getItem('hf_shop_checked') || '{}');
  document.getElementById('shop-items').innerHTML = items.map((item, i) => {
    const amt = item.hasAmt && item.total > 0
      ? (() => { const t = Math.round(item.total*10)/10; return (t%1===0?t.toFixed(0):t.toFixed(1)) + (item.unit?' '+item.unit:''); })()
      : '';
    const display = amt ? `${item.name} <span class="text-gray-400">(${amt})</span>` : item.name;
    const checked = !!saved[item.name];
    return `
      <label class="flex items-center gap-3 px-4 py-3 cursor-pointer hover:bg-gray-50 ${checked?'opacity-50':''}"
             id="row-${i}" for="si-${i}">
        <input type="checkbox" id="si-${i}" class="w-4 h-4 shop-check" ${checked?'checked':''}
               onchange="toggleShopItem('${item.name.replace(/'/g,"\\'")}', ${i}, this.checked)"/>
        <span class="text-sm flex-1 ${checked?'line-through text-gray-400':''}" id="sl-${i}">${display}</span>
      </label>`;
  }).join('');
}

function toggleShopItem(name, i, checked) {
  const saved = JSON.parse(localStorage.getItem('hf_shop_checked')||'{}');
  saved[name] = checked;
  localStorage.setItem('hf_shop_checked', JSON.stringify(saved));
  const row = document.getElementById('row-' + i);
  const lbl = document.getElementById('sl-' + i);
  row.classList.toggle('opacity-50', checked);
  lbl.classList.toggle('line-through', checked);
  lbl.classList.toggle('text-gray-400', checked);
}

function clearShop() {
  localStorage.removeItem('hf_shop_checked');
  renderShop();
}

// ── Adults slider ─────────────────────────────────────────────────
function onAdults(slider) {
  adults = parseInt(slider.value);
  document.getElementById('adults-val').textContent = adults;
  localStorage.setItem('hf_adults', adults);
  // Scale visible ingredient labels
  document.querySelectorAll('.ingredient-item').forEach(el => {
    const a = parseFloat(el.dataset.amount), b = parseFloat(el.dataset.base)||2;
    if (!isNaN(a) && a > 0) {
      const s = Math.round(a/b*adults*10)/10;
      el.textContent = (s%1===0?s.toFixed(0):s.toFixed(1))+(el.dataset.unit?' '+el.dataset.unit:'')+' '+el.dataset.name;
    }
  });
  if (!document.getElementById('pane-shop').classList.contains('hidden')) renderShop();
}

// ── Init ──────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  // Restore adults
  document.getElementById('adults-slider').value = adults;
  document.getElementById('adults-val').textContent = adults;

  // Restore selections
  selected.forEach(idx => {
    const cb = document.getElementById('chk-' + idx);
    if (cb) { cb.checked = true; onCheck(idx, true); }
  });
});

if ('serviceWorker' in navigator) navigator.serviceWorker.register('service-worker.js').catch(()=>{});
</script>
</body>
</html>
